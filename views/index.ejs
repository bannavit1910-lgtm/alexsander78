<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title><%= storeName %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="wrap">
  <%- include('partials/nav') %>

  <section class="hero">
    <div class="hero-text">
      <h1>ไอดีเกมและสกินคุณภาพ<br>ระดับ <span>เทพ</span> ในที่เดียว</h1>
      <p><%= storeName %> — เติมเงินง่าย ปลอดภัย ดูแลสมาชิกทุกระดับ</p>
    </div>
    <div class="hero-visual">
      <svg viewBox="0 0 400 500" xmlns="http://www.w3.org/2000/svg" class="hero-char">
        <defs>
          <radialGradient id="auraGlow" cx="50%" cy="42%" r="55%">
            <stop offset="0%" stop-color="var(--rare)" stop-opacity="0.55"/>
            <stop offset="55%" stop-color="var(--epic)" stop-opacity="0.25"/>
            <stop offset="100%" stop-color="var(--epic)" stop-opacity="0"/>
          </radialGradient>
          <linearGradient id="armorGrad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#3a3f55"/>
            <stop offset="100%" stop-color="#181a24"/>
          </linearGradient>
          <linearGradient id="capeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="var(--epic)"/>
            <stop offset="100%" stop-color="#181a24"/>
          </linearGradient>
          <linearGradient id="bladeGrad" x1="0%" y1="100%" x2="0%" y2="0%">
            <stop offset="0%" stop-color="var(--rare)"/>
            <stop offset="100%" stop-color="#eafffb"/>
          </linearGradient>
        </defs>

        <circle cx="200" cy="220" r="190" fill="url(#auraGlow)"/>

        <g class="floaty-particles">
          <circle cx="70" cy="120" r="3" fill="var(--legend)"/>
          <circle cx="335" cy="150" r="2.5" fill="var(--rare)"/>
          <circle cx="90" cy="340" r="2.5" fill="var(--epic)"/>
          <circle cx="320" cy="360" r="3" fill="var(--legend)"/>
          <circle cx="200" cy="60" r="2" fill="var(--rare)"/>
        </g>

        <path d="M200 150 C 150 165, 120 220, 130 290 L 145 470 L 255 470 L 270 290 C 280 220, 250 165, 200 150 Z" fill="url(#capeGrad)" opacity="0.85"/>

        <ellipse cx="200" cy="470" rx="70" ry="10" fill="#000" opacity="0.35"/>

        <path d="M200 168 C 168 168, 150 195, 150 225 L 150 300 C 150 330, 170 345, 200 345 C 230 345, 250 330, 250 300 L 250 225 C 250 195, 232 168, 200 168 Z" fill="url(#armorGrad)" stroke="var(--rare)" stroke-width="1.5"/>

        <path d="M200 168 L 185 205 L 200 220 L 215 205 Z" fill="var(--legend)" stroke="#181a24" stroke-width="1"/>

        <rect x="150" y="215" width="18" height="55" rx="6" fill="url(#armorGrad)" stroke="var(--epic)" stroke-width="1.2"/>
        <rect x="232" y="215" width="18" height="55" rx="6" fill="url(#armorGrad)" stroke="var(--epic)" stroke-width="1.2"/>

        <rect x="180" y="330" width="18" height="80" rx="6" fill="url(#armorGrad)" stroke="var(--line)" stroke-width="1"/>
        <rect x="202" y="330" width="18" height="80" rx="6" fill="url(#armorGrad)" stroke="var(--line)" stroke-width="1"/>
        <rect x="175" y="404" width="26" height="16" rx="4" fill="#101218" stroke="var(--rare)" stroke-width="1"/>
        <rect x="199" y="404" width="26" height="16" rx="4" fill="#101218" stroke="var(--rare)" stroke-width="1"/>

        <circle cx="200" cy="120" r="34" fill="url(#armorGrad)" stroke="var(--rare)" stroke-width="1.5"/>
        <path d="M172 108 C 178 90, 222 90, 228 108 C 232 118, 224 128, 200 130 C 176 128, 168 118, 172 108 Z" fill="#0f1017"/>
        <rect x="185" y="112" width="30" height="6" rx="3" fill="var(--rare)"/>

        <g class="hero-blade">
          <rect x="258" y="90" width="10" height="130" rx="3" transform="rotate(18 263 155)" fill="url(#bladeGrad)"/>
          <rect x="248" y="205" width="30" height="14" rx="3" transform="rotate(18 263 212)" fill="var(--legend)"/>
          <rect x="255" y="215" width="14" height="34" rx="4" transform="rotate(18 262 232)" fill="#181a24" stroke="var(--epic)" stroke-width="1"/>
        </g>

        <rect x="132" y="240" width="16" height="46" rx="6" transform="rotate(-8 140 263)" fill="url(#armorGrad)" stroke="var(--epic)" stroke-width="1.2"/>
      </svg>
    </div>
  </section>

  <% if (categoryCounts && categoryCounts.length > 0) { %>
  <div class="category-banners">
    <% const bannerColors = ['var(--rare)','var(--epic)','var(--legend)','var(--danger)']; %>
    <% categoryCounts.forEach((c, i) => { %>
      <a class="banner-item" href="/?category=<%= encodeURIComponent(c.name) %>">
        <% if (c.image) { %>
          <span class="banner-thumb"><img src="<%= c.image %>" alt="<%= c.title %>"></span>
        <% } else { %>
          <span class="banner-badge" style="background:<%= bannerColors[i % bannerColors.length] %>;"></span>
        <% } %>
        <span class="banner-text">
          <span class="banner-text-main"><%= c.title %></span>
          <span class="banner-text-sub"><%= c.subtitle %></span>
        </span>
      </a>
    <% }) %>
  </div>
  <% } %>

  <div class="filters">
    <a class="tab <%= activeCategory === 'ทั้งหมด' ? 'active' : '' %>" href="/">ทั้งหมด</a>
    <% categories.forEach(c => { %>
      <a class="tab <%= activeCategory === c ? 'active' : '' %>" href="/?category=<%= encodeURIComponent(c) %>"><%= c %></a>
    <% }) %>
  </div>

  <div class="section-head">
    <h2>สินค้าทั้งหมด</h2>
  </div>

  <% if (products.length === 0) { %>
    <p class="empty-note">ยังไม่มีสินค้าในหมวดนี้</p>
  <% } %>

  <div class="grid">
    <% products.forEach(p => { %>
      <div class="card">
        <div class="thumb">
          <div class="rarity-ribbon <%= p.rarity %>"><%= p.rarity === 'legend' ? 'LEGENDS' : (p.rarity === 'epic' ? 'EPIC' : 'RARE') %></div>
          <% if (p.is_best_seller) { %><div class="badge-best">ขายดี</div><% } %>
          <% if (p.discount_percent > 0) { %><div class="badge-sale">-<%= p.discount_percent %>%</div><% } %>
          <% if (p.image_path) { %>
            <img src="<%= p.image_path %>" alt="<%= p.title %>">
          <% } else { %>
            <div class="thumb-placeholder thumb-<%= p.rarity %>">
              <span class="thumb-glow"></span>
              <span class="thumb-label"><%= p.title %></span>
            </div>
          <% } %>
        </div>
        <div class="info">
          <div class="title"><%= p.title %></div>
          <div class="price-row">
            <span class="now">฿<%= ((p.price * (100 - p.discount_percent) / 100) / 100).toFixed(2) %></span>
            <% if (p.discount_percent > 0) { %><span class="was">฿<%= (p.price / 100).toFixed(2) %></span><% } %>
          </div>
          <div class="stock-note"><%= p.stock > 0 ? `เหลือ ${p.stock} รายการ` : 'สินค้าหมด' %></div>
          <% if (currentUser) { %>
            <% const unitPriceBaht = ((p.price * (100 - p.discount_percent) / 100) / 100); %>
            <div class="qty-stepper" data-max="<%= p.stock %>">
              <button type="button" class="qty-btn qty-minus" aria-label="ลดจำนวน">−</button>
              <input type="number" class="qty-input" value="1" min="1" max="<%= p.stock %>" inputmode="numeric">
              <button type="button" class="qty-btn qty-plus" aria-label="เพิ่มจำนวน">+</button>
            </div>
            <button
              type="button"
              class="btn btn-primary btn-block btn-buy-open"
              <%= p.stock <= 0 ? 'disabled' : '' %>
              data-product-id="<%= p.id %>"
              data-product-title="<%= p.title %>"
              data-unit-price="<%= unitPriceBaht.toFixed(2) %>"
              data-stock="<%= p.stock %>"
              data-product-desc="<%= p.description || '' %>"
              data-product-image="<%= p.image_path || '' %>"
            >ซื้อสินค้านี้</button>
          <% } else { %>
            <a class="btn btn-ghost btn-block" href="/login">เข้าสู่ระบบเพื่อซื้อ</a>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<!-- ป็อปอัพยืนยันการซื้อสินค้า -->
<div class="modal-overlay" id="buyModalOverlay">
  <div class="modal-box" role="dialog" aria-modal="true" aria-labelledby="buyModalTitle">
    <h3 id="buyModalTitle">ยืนยันการสั่งซื้อ</h3>
    <img id="buyModalImage" class="modal-product-image" alt="" style="display:none;">
    <div class="modal-row">
      <span class="modal-label">สินค้า</span>
      <span class="modal-value" id="buyModalProductName">-</span>
    </div>
    <div class="modal-desc" id="buyModalDesc" style="display:none;"></div>
    <div class="modal-row">
      <span class="modal-label">จำนวน</span>
      <span class="modal-value" id="buyModalQty">-</span>
    </div>
    <div class="modal-row modal-row-total">
      <span class="modal-label">ยอดชำระทั้งหมด</span>
      <span class="modal-value modal-total" id="buyModalTotal">฿0.00</span>
    </div>
    <form method="POST" id="buyModalForm" action="">
      <input type="hidden" name="quantity" id="buyModalQtyInput" value="1">
      <div class="modal-actions">
        <button type="button" class="btn btn-ghost" id="buyModalCancel">ยกเลิก</button>
        <button type="submit" class="btn btn-primary">ยืนยันการซื้อ</button>
      </div>
    </form>
  </div>
</div>

<script>
(function () {
  // ตัวควบคุมจำนวนสินค้า (ปุ่ม + / -) ในแต่ละการ์ดสินค้า
  document.querySelectorAll('.qty-stepper').forEach(function (stepper) {
    var input = stepper.querySelector('.qty-input');
    var minusBtn = stepper.querySelector('.qty-minus');
    var plusBtn = stepper.querySelector('.qty-plus');
    var max = parseInt(stepper.dataset.max, 10) || 1;

    function clamp() {
      var val = parseInt(input.value, 10);
      if (!Number.isInteger(val) || val < 1) val = 1;
      if (val > max) val = max;
      input.value = val;
    }

    minusBtn.addEventListener('click', function () {
      var val = parseInt(input.value, 10) || 1;
      input.value = Math.max(1, val - 1);
    });

    plusBtn.addEventListener('click', function () {
      var val = parseInt(input.value, 10) || 1;
      input.value = Math.min(max, val + 1);
    });

    input.addEventListener('change', clamp);
    input.addEventListener('blur', clamp);
  });

  // ป็อปอัพยืนยันการซื้อ
  var overlay = document.getElementById('buyModalOverlay');
  var form = document.getElementById('buyModalForm');
  var qtyInputHidden = document.getElementById('buyModalQtyInput');
  var nameEl = document.getElementById('buyModalProductName');
  var imageEl = document.getElementById('buyModalImage');
  var descEl = document.getElementById('buyModalDesc');
  var qtyEl = document.getElementById('buyModalQty');
  var totalEl = document.getElementById('buyModalTotal');
  var cancelBtn = document.getElementById('buyModalCancel');

  function openModal(btn) {
    var card = btn.closest('.card');
    var qtyInput = card.querySelector('.qty-input');
    var qty = parseInt(qtyInput.value, 10) || 1;
    var unitPrice = parseFloat(btn.dataset.unitPrice) || 0;
    var productId = btn.dataset.productId;
    var productTitle = btn.dataset.productTitle;
    var productDesc = btn.dataset.productDesc || '';
    var productImage = btn.dataset.productImage || '';

    nameEl.textContent = productTitle;
    if (productImage) {
      imageEl.src = productImage;
      imageEl.alt = productTitle;
      imageEl.style.display = 'block';
    } else {
      imageEl.removeAttribute('src');
      imageEl.style.display = 'none';
    }
    if (productDesc.trim()) {
      descEl.textContent = productDesc;
      descEl.style.display = 'block';
    } else {
      descEl.textContent = '';
      descEl.style.display = 'none';
    }
    qtyEl.textContent = qty + ' ชิ้น';
    totalEl.textContent = '฿' + (unitPrice * qty).toFixed(2);
    qtyInputHidden.value = qty;
    form.action = '/buy/' + productId;

    overlay.classList.add('open');
  }

  function closeModal() {
    overlay.classList.remove('open');
  }

  document.querySelectorAll('.btn-buy-open').forEach(function (btn) {
    btn.addEventListener('click', function () {
      openModal(btn);
    });
  });

  cancelBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', function (e) {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });
})();
</script>
</body>
</html>
